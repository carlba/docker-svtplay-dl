{
  "name": "docker-svtplay-dl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file-if-exists='.env' dist/index.js",
    "start:dev": "tsx --env-file-if-exists=.env --watch src/index.ts",
    "build-watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dependency:update": "npx ncu -u",
    "linux:install": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye npm install",
    "linux:ci": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye bash -lc \"npm ci && npm run lint && npm test && npm run build\""
  },
  "dependencies": {
    "croner": "^10.0.1",
    "got": "^12.0.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "nock": "^14.0.15",
    "npm-check-updates": "21.0.3",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.5"
  },
  "homepage": "https://github.com/carlba/docker-svtplay-dl",
  "repository": {
    "type": "git",
    "url": "git@github.com:carlba/docker-svtplay-dl"
  },
  "author": "carlba",
  "bugs": {
    "url": "https://github.com/carlba/docker-svtplay-dl/issues"
  },
  "templater": {
    "managedDependencies": [
      "pino",
      "pino-pretty",
      "zod"
    ],
    "managedDevDependencies": [
      "eslint",
      "@eslint/js",
      "@tsconfig/node24",
      "@types/node",
      "@vitest/coverage-v8",
      "npm-check-updates",
      "prettier",
      "tsx",
      "typescript",
      "typescript-eslint",
      "vitest"
    ],
    "managedScripts": [
      "build",
      "build-watch",
      "start",
      "start:dev",
      "test",
      "test:watch",
      "test:coverage",
      "lint",
      "format",
      "format:check",
      "dependency:update",
      "linux:install",
      "linux:ci"
    ]
  }
}
